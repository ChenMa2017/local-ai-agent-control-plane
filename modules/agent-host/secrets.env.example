# Copy to:
#   ~/.config/agent-host/secrets.env
#
# Then protect it:
#   chmod 600 ~/.config/agent-host/secrets.env
#
# Keep real values out of Git, chat messages, screenshots, and shell history.

DISCORD_BOT_TOKEN=replace-with-discord-bot-token
DISCORD_GUILD_ID=replace-with-discord-guild-id
AGENT_HOST_TOKEN=replace-with-agent-host-token
AGENT_HOST_ADMIN_TOKEN=replace-with-agent-host-admin-token
